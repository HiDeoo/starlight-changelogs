  "homepage": "https://github.com/HiDeoo/starlight-changelogs",
  "repository": {
    "type": "git",
    "url": "https://github.com/HiDeoo/starlight-changelogs.git",
    "directory": "packages/starlight-changelogs"
  },
  "bugs": "https://github.com/HiDeoo/starlight-changelogs/issues"
